# Neon Postgres (use Vercel ↔ Neon integration to auto-inject on deploys)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Only needed if you front DATABASE_URL with pgbouncer/PgPool and need a
# direct connection for `prisma migrate`. Add `directUrl = env("DIRECT_URL")`
# to prisma/schema.prisma when you set this.
# DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Auth.js v5
# - AUTH_SECRET: generate with `npx auth secret`
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID)
# Redirect URI: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (https://resend.com) — used for magic-link sign-in
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Pesa <onboarding@resend.dev>"
